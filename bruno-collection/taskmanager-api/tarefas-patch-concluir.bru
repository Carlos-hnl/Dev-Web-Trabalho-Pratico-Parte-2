meta {
  name: Alternar Conclusao (PATCH)
  type: http
  seq: 8
}

patch {
  url: {{baseUrl}}/tarefas/1/concluir
  body: none
  auth: none
}

tests {
  test("Status 200 ou 404", function() {
    const status = res.getStatus();
    expect([200, 404]).to.include(status);
  });

  test("Resposta tem campo sucesso", function() {
    expect(res.getBody()).to.have.property("sucesso");
  });
}
